{
  "defaults": {
    "standard": "WCAG2AA",
    "runners": ["axe"],
    "timeout": 30000,
    "wait": 500,
    "threshold": 0,
    "chromeLaunchConfig": {
      "args": ["--no-sandbox", "--disable-dev-shm-usage"]
    },
    "ignore": []
  },
  "urls": [
    "http://127.0.0.1:4000/",
    "http://127.0.0.1:4000/apps",
    "http://127.0.0.1:4000/get_a_pod",
    "http://127.0.0.1:4000/for_developers",
    "http://127.0.0.1:4000/for_users",
    "http://127.0.0.1:4000/community"
  ]
}
